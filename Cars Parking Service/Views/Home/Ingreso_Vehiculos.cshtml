@{
    ViewData["Title"] = "Ingresar Vehiculo";
}

<div id="client-error-container" style="display:none;position:fixed;top:10px;left:10px;right:10px;z-index:9999;background:#fee;border:1px solid #f99;padding:10px;border-radius:6px;color:#600;max-height:40vh;overflow:auto;"></div>

<div class="ingreso-container">
    <div class="logo-section">
        <div class="car-logo">
            <img src="~/img/logo cars parking.png" alt="Cars Parking Logo" class="logo-img">
        </div>
    </div>

    <h1 class="ingreso-title">Ingresar Vehiculo</h1>

    @if (TempData["ModelStateErrors"] != null)
    {
        <div class="error-credenciales">
            <span class="error-text">⚠️ Errores de validación: @TempData["ModelStateErrors"]</span>
        </div>
    }

    @if (ViewBag.Error != null) {
        <div class="error-credenciales">
            <span class="error-text">⚠️ @ViewBag.Error</span>
        </div>
    }

    <form method="post" asp-action="IngresoVehiculos" asp-controller="Home" id="ingresoForm" enctype="multipart/form-data">
        <div class="input-group">
            <input type="text"
                   name="placa"
                   id="placa"
                   placeholder="ABC123"
                   pattern="[A-Z]{3}[0-9]{3}"
                   maxlength="6"
                   style="text-transform: uppercase;"
                   required>
            <div class="error-message" id="errorPlaca">⚠️ La Placa es obligatoria (Formato: ABC123)</div>
        </div>

        <div class="input-group">
            <input type="text"
                   name="nombre_cliente"
                   id="nombre_cliente"
                   placeholder="Nombre del Cliente"
                   maxlength="100"
                   required>
        </div>

        <div class="input-group">
            <input type="tel"
                   name="telefono"
                   id="telefono"
                   placeholder="Teléfono del Cliente"
                   maxlength="20"
                   required>
            <div class="error-message" id="errorTelefono">⚠️ El teléfono es obligatorio</div>
        </div>

        <!-- Selección de Valet -->
        <div class="input-group">
                <select name="id_valet" id="id_valet" style="width:100%;" required>
                <option value="">Selecciona un Valet</option>
                @foreach(var valet in ViewBag.Valets){
                    <option value="@valet.id_usuario">@valet.nombres @valet.apellidos</option>
                }
                
                @if (ViewBag.UsuarioSesion?.usuario_rol == 2)
                {
                    <option value="@ViewBag.UsuarioSesion?.IdUsuario">@ViewBag.UsuarioSesion?.nombre @ViewBag.UsuarioSesion?.apellido (banco)</option>
                }
            </select>
            <div class="error-message" id="errorValet">⚠️ Selecciona un valet</div>
        </div>

        <!-- Banco (Usuario en sesión - no editable) -->
        <div class="input-group">
            <input type="text"
                    id="banco_display"
                    value="@ViewBag.UsuarioSesion?.nombre @ViewBag.UsuarioSesion?.apellido"
                    placeholder="Banco/Cajero"
                    readonly
                    style="background-color: #f5f5f5; cursor: not-allowed;">

            <input type="hidden"
                    name="id_banco"
                    value="@ViewBag.UsuarioSesion?.IdUsuario">

            <div class="error-message" id="errorBanco">⚠️ No hay un cajero en sesión</div>
        </div>

        <!-- Selección de Parqueadero -->
        <div class="input-group">
                <select name="id_parqueadero" id="id_parqueadero" style="width:100%;" required>
                <option value="">Selecciona un Parqueadero</option>
                    @foreach (var parqueadero in ViewBag.Parqueaderos)
                    {
                        <option value="@parqueadero.id_parqueadero">@parqueadero.nombre_parqueadero</option>
                    }
            </select>
            <div class="error-message" id="errorParqueadero">⚠️ Selecciona un parqueadero</div>
        </div>

        <!-- Selección de Ubicación -->
        <div class="input-group">
                <select name="id_ubicacion" id="id_ubicacion" style="width:100%;" required>
                <option value="">Selecciona una Ubicación</option>
                    @foreach (var ubicacionesS in ViewBag.UbicacionesS)
                    {
                        <option value="@ubicacionesS.id_ubicacion">@ubicacionesS.nombre_ubicacion</option>
                    }
            </select>
            <div class="error-message" id="errorUbicacion">⚠️ Selecciona una ubicación</div>
        </div>

        <!-- Notas/Valuables -->
        <div class="input-group notas-group">
            <textarea name="notas" id="notas" placeholder="Objetos de valor (opcional)" rows="3"></textarea>
            <input type="hidden" name="sin_objetos_valor" id="sin_objetos_valor_hidden" value="false" style="width:100%;" />
            <button type="button" class="notas-toggle-btn" id="noValuablesBtn">
                <i class="fa-solid fa-shield-check"></i>
                No hay objetos de valor
            </button>
        </div>

        <!-- ========== FOTOS Y VIDEO DEL VEHÍCULO ========== -->
        <div class="photo-section">
            <h4 class="photo-title">Fotos y Video del Vehiculo</h4>

            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                <button type="button" class="photo-btn" id="tomarFotoBtn">
                    <svg class="camera-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                        <circle cx="12" cy="13" r="4"></circle>
                    </svg>
                    Tomar Foto
                </button>
                <button type="button" class="photo-btn" id="grabarVideoBtn">
                    <svg class="camera-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="7" width="15" height="10" rx="2" ry="2"></rect>
                        <polygon points="21 7 21 17 23 17 23 7 21 7"></polygon>
                    </svg>
                    Grabar Video
                </button>
            </div>

            <p class="photo-counter" id="photoCounter">0 fotos seleccionadas (max. 10)</p>

            <!-- Contenedor padre para fotos y el video -->
            <div class="Media-Preview">
                <!-- Contenedor para preview de fotos -->
                <div class="photos-preview" id="photosPreview"></div>

                <!-- Contenedor para preview de video -->
                <div id="videoPreviewContainer" style="margin-top: 12px;"></div>
            </div>

            <!-- Input oculto para invocar la cámara nativa del dispositivo SOLO para fotos -->
            <input type="file" id="cameraInput" accept="image/*" capture style="display:none;">
            <!-- Input oculto para grabar video (sin capture para máxima compatibilidad móvil) -->
            <input type="file" id="videoInput" accept="video/*" style="display:none;">

            <!-- Inputs ocultos para enviar los archivos como base64 -->
            <div id="fotosBase64Container"></div>
            <input type="hidden" name="videoBase64" id="videoBase64Input" />
            <div class="error-message" id="errorMedia" style="display:none;"></div>
        </div>

        <!-- Firma del cliente (canvas centralizado, solo lógica de site.js) -->
        <div class="firma-section">
            <h3 class="firma-title">Firma del Cliente</h3>
            <div class="firma-canvas-container" style="width:100%;max-width:340px;margin:auto;">
                <canvas id="firmaCanvas" width="340" height="160" style="width:100%;height:160px;border:1px solid #ccc;touch-action: none;"></canvas>
            </div>
            <div class="firma-actions">
                <button type="button" class="firma-btn-limpiar" id="limpiarFirma">
                    <i class="fa-solid fa-eraser"></i> Limpiar
                </button>
            </div>
            <div class="error-message" id="errorFirma">⚠️ La firma del cliente es obligatoria</div>
            <input type="hidden" id="firmaBase64" name="firmaBase64">
        </div>
        <button type="submit" class="ingreso-btn" id="acceder">Ingresar</button>
    </form>
</div>

<!-- Modal de grabación de video (minimalista, cámara trasera, controles sobre el video) -->
<div id="videoModal" style="display:none;position:fixed;z-index:9999;top:0;left:0;width:100vw;height:100vh;background:#000;justify-content:center;align-items:center;flex-direction:column;">
    <div style="position:relative;width:100vw;height:100vh;overflow:hidden;">
        <video id="liveVideo" autoplay playsinline style="width:100vw;height:100vh;object-fit:cover;background:#000;"></video>
        <!-- Controles sobre el video -->
        <div style="position:absolute;top:0;left:0;width:100vw;z-index:2;display:flex;flex-direction:row;align-items:center;justify-content:space-between;pointer-events:none;">
            <div style="width:80vw;height:7px;background:#222;border-radius:4px;overflow:hidden;margin:18px 0 0 18px;">
                <div id="recordProgressBar" style="height:100%;width:0%;background:#e53935;transition:width 0.2s;"></div>
            </div>
            <span id="recordTimer" style="color:#fff;font-size:1.2em;margin:18px 18px 0 12px;letter-spacing:1px;pointer-events:auto;">00:00</span>
        </div>
        <button id="startRecordingBtn" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);width:56px;height:56px;border-radius:50%;background:#e53935;border:none;box-shadow:0 2px 8px #0006;z-index:3;display:flex;align-items:center;justify-content:center;pointer-events:auto;">
            <span style="display:inline-block;width:32px;height:32px;background:#fff;border-radius:50%;margin:10px auto;"></span>
        </button>
        <button id="stopRecordingBtn" style="display:none;position:absolute;bottom:40px;left:50%;transform:translateX(-50%);width:56px;height:56px;border-radius:50%;background:#e53935;border:none;box-shadow:0 2px 8px #0006;z-index:3;align-items:center;justify-content:center;pointer-events:auto;">
            <span style="display:inline-block;width:32px;height:32px;background:#fff;border-radius:8px;margin:10px auto;"></span>
        </button>
        <button id="closeVideoModalBtn" style="position:absolute;top:18px;right:18px;font-size:2.2em;color:#fff;background:none;border:none;z-index:4;pointer-events:auto; margin-top: 15px;">&times;</button>
        <div id="videoReviewSection" style="display:none;position:absolute;top:0;left:0;width:100vw;height:100vh;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,0.92);z-index:10;">
            <video id="recordedVideo" controls style="width:100vw;height:100vh;object-fit:cover;background:#000;"></video>
            <button id="acceptVideoBtn" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);width:56px;height:56px;border-radius:50%;background:transparent;border:none;box-shadow:none;display:flex;align-items:center;justify-content:center;pointer-events:auto;">
                <i class="fa-solid fa-check" style="font-size:2em;color:#fff;"></i>
            </button>
            <button id="deleteVideoBtn" class="delete-photo" style="position:absolute;top:30px;right:30px;width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,0.7);border:none;box-shadow:0 2px 8px #0006;display:flex;align-items:center;justify-content:center;pointer-events:auto;z-index:11;">
                <span style="font-size:1.5em;color:#fff;">&times;</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ingreso-vehiculos.js" asp-append-version="true" defer></script>
    <script src="~/js/ingreso-vehiculos-camera.js" asp-append-version="true" defer></script>
    <script>
        // AJAX submit via fetch but DO NOT redirect or refresh page on success
        (function() {
            const form = document.getElementById('ingresoForm');
            if (!form) return;

            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                // client-side HTML5 validation
                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                // Ensure signature is sent even if the external JS didn't populate the hidden field
                const firmaInput = document.getElementById('firmaBase64');
                const firmaCanvas = document.getElementById('firmaCanvas');
                if (firmaInput && !firmaInput.value && firmaCanvas && typeof firmaCanvas.toDataURL === 'function') {
                    firmaInput.value = firmaCanvas.toDataURL('image/png');
                }

                const formData = new FormData(form);
                const submitBtn = document.getElementById('acceder');
                const originalText = submitBtn ? submitBtn.innerHTML : null;
                if (submitBtn) { submitBtn.disabled = true; submitBtn.innerHTML = 'Ingresando...'; }

                try {
                    const resp = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (!resp.ok) {
                        const text = await resp.text();
                        console.error('Error servidor:', resp.status, text);
                        alert('Ocurrió un error al ingresar. Revisa la consola para detalles.');
                        return;
                    }

                    // Try parse JSON response
                    let data = null;
                    const contentType = resp.headers.get('content-type') || '';
                    if (contentType.indexOf('application/json') !== -1) {
                        data = await resp.json();
                    }

                    // Optional: clear form fields that should be reset
                    try {
                        form.reset();
                        // clear previews if your JS uses them
                        const photosPreview = document.getElementById('photosPreview'); if (photosPreview) photosPreview.innerHTML = '';
                        const videoPreview = document.getElementById('videoPreviewContainer'); if (videoPreview) videoPreview.innerHTML = '';
                        if (firmaInput) firmaInput.value = '';
                    } catch (ex) { console.warn('No se pudo limpiar el formulario', ex); }

                } catch (err) {
                    console.error('Error enviando formulario:', err);
                    alert('Error de red al intentar ingresar. Revisa la consola.');
                } finally {
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = originalText; }
                }
            });
        })();
    </script>
}