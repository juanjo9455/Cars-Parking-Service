            // Función para confirmar guardar cambios en el modal de edición de usuario
            function confirmarGuardarUsuario() {
                var form = document.getElementById('formEditarUsuario');

                if (form.checkValidity()) {
                    // Si el formulario es válido, lo enviamos
                    form.submit();
                } else {
                    // Si el formulario no es válido, mostramos un mensaje de error
                    alert('Por favor, completa todos los campos requeridos correctamente.');
                }
            }

            // Función para confirmar guardar cambios en el modal de edición de ubicación
            function confirmarGuardarUbicacion() {
                var form = document.getElementById('formEditarUbicacion');

                if (form.checkValidity()) {
