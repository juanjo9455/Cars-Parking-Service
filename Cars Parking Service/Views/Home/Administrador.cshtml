                    alert('Por favor, completa todos los campos requeridos correctamente.');
                }
            }

            // Función para tomar foto de avatar con la cámara
            document.getElementById('btnTomarFotoAvatar').onclick = function() {
                var video = document.createElement('video');
                var constraints = {
                    video: { facingMode: "environment" } // Usar la cámara trasera en dispositivos móviles
                };

                // Solicitar acceso a la cámara
                navigator.mediaDevices.getUserMedia(constraints)
                    .then(function(stream) {
                        video.srcObject = stream;
                        video.play();

                        // Abrir un modal o overlay con el video en vivo
                        var modal = document.createElement('div');
                        modal.className = 'video-modal';
                        modal.style.position = 'fixed';
                        modal.style.top = 0;
                        modal.style.left = 0;
                        modal.style.width = '100%';
                        modal.style.height = '100%';
                        modal.style.backgroundColor = 'rgba(0, 0, 0, 0.8)';
                        modal.style.zIndex = 9999;
                        modal.appendChild(video);

                        // Agregar botón de captura
                        var captureButton = document.createElement('button');
                        captureButton.innerHTML = '<i class="fa-solid fa-camera" style="color: white;"></i> Capturar';
                        captureButton.className = 'btn-capture';
                        captureButton.style.position = 'absolute';
                        captureButton.style.bottom = '20px';
                        captureButton.style.left = '50%';
                        captureButton.style.transform = 'translateX(-50%)';
                        captureButton.style.padding = '10px 20px';
                        captureButton.style.fontSize = '16px';
                        captureButton.style.border = 'none';
                        captureButton.style.borderRadius = '5px';
                        captureButton.style.cursor = 'pointer';
                        captureButton.style.backgroundColor = '#d32f2f';
                        modal.appendChild(captureButton);

                        document.body.appendChild(modal);

                        // Función para capturar la foto
                        captureButton.onclick = function() {
                            var canvas = document.createElement('canvas');
                            var context = canvas.getContext('2d');
                            canvas.width = video.videoWidth;
                            canvas.height = video.videoHeight;
                            context.drawImage(video, 0, 0, canvas.width, canvas.height);

                            // Detener el stream de video y cerrar el modal
                            var tracks = video.srcObject.getTracks();
                            tracks.forEach(function(track) { track.stop(); });
                            document.body.removeChild(modal);
                            video.remove();

                            // Obtener la imagen en formato base64
                            var imgBase64 = canvas.toDataURL('image/jpeg');

                            // Asignar la imagen al campo oculto del formulario
                            document.getElementById('edit_avatar_base64').value = imgBase64;

                            // Mostrar la miniatura en el formulario
                            var avatarPreview = document.getElementById('editAvatarPreview');
                            avatarPreview.src = imgBase64;
                            avatarPreview.style.display = 'block';

                            var avatarIcon = document.getElementById('editAvatarIcon');
                            avatarIcon.style.display = 'none';
                        };
                    })
                    .catch(function(error) {
                        console.error('Error accediendo a la cámara: ', error);
                    });
            };

