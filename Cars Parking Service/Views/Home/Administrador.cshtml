                document.getElementById('TablaUbicacionesContainer').style.display = 'none';
                document.getElementById('SubCardsParqueaderos').style.display = 'none';
                document.getElementById('TablaParqueaderosContainer').style.display = 'none';

                // Mostramos u ocultamos el panel de usuarios
                if (isVisible) {
                    subCards.style.display = 'none';
                    tabla.style.display = 'none';
                    document.getElementById('titulo-principal').style.display = 'block';
                } else {
                    subCards.style.display = 'flex';
                    tabla.style.display = 'none';
                    document.getElementById('titulo-principal').style.display = 'none';
                }
