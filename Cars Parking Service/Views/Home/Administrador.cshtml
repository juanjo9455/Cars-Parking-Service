                document.getElementById('edit_telefono').value = telefono;
                document.getElementById('edit_edad').value = edad;
                document.getElementById('edit_correo').value = correo;
                document.getElementById('edit_rol').value = id_rol;

                // Manejo del estado (activo/inactivo)
                document.getElementById('edit_estado').value = (estado === 'true') ? 'true' : 'false';
                document.getElementById('edit_estado_select').value = (estado === 'true') ? 'true' : 'false';

                // Mostrar el avatar si existe
                var avatarPreview = document.getElementById('editAvatarPreview');
                var avatarIcon = document.getElementById('editAvatarIcon');
                if (avatar) {
                    avatarPreview.src = avatar;
                    avatarPreview.style.display = 'block';
                    avatarIcon.style.display = 'none';
                } else {
                    avatarPreview.style.display = 'none';
                    avatarIcon.style.display = 'block';
