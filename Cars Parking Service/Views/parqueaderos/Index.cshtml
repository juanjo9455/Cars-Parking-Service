@model IEnumerable<CarsParkingService.Models.parqueaderos>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.direccion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ciudad)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.nombre_parqueadero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.tarifa)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.direccion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ciudad)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.nombre_parqueadero)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.tarifa)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.id_parqueadero">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id_parqueadero">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id_parqueadero">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

