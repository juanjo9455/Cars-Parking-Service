@{
    ViewData["Title"] = "Recuperar contraseña";
}
<div class="forgot-password-container">
    <div class="forgot-card">
        <div class="logo-section">
            <img src="~/img/logo cars parking.png" alt="Cars Parking Logo" class="logo-img">
        </div>

        <div class="forgot-header">
            <h1 class="forgot-title">¿Olvidaste tu contraseña?</h1>
            <p class="forgot-subtitle">No te preocupes, te enviaremos instrucciones para restablecerla</p>
        </div>

        @if (ViewBag.Error != null || TempData["Error"] != null)
        {
            <div class="error-credenciales">
                <span class="error-text">⚠️ @(ViewBag.Error ?? TempData["Error"])</span>
            </div>
        }

        @if (TempData["Mensaje"] != null)
        {
            <div class="success-message">
                @TempData["Mensaje"]
            </div>
        }

        <form method="post" asp-controller="Auth" asp-action="ForgotPassword" id="forgotPasswordForm" novalidate>
            @Html.AntiForgeryToken()
            <div class="input-group">
                <label for="email" class="input-label">Correo electrónico</label>
                <input type="email"
                       id="email"
                       name="email"
                       placeholder="ejemplo@correo.com"
                       required>
                <div class="error-message" id="errorEmail">⚠️ Ingresa un correo válido</div>
            </div>

            <button type="submit" class="login-btn" id="acceder">Enviar Instrucciones</button>

            <div class="forgot-password">
                <a asp-controller="Auth" asp-action="Login">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    Volver al inicio de sesión
                </a>
            </div>
        </form>
    </div>
</div>
