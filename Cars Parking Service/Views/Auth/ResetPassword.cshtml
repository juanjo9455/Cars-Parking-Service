@{
    ViewData["Title"] = "Nueva contraseña";
}

<div class="forgot-password-container">
    <div class="forgot-card">
        <div class="logo-section">
            <img src="~/img/logo cars parking.png" alt="Cars Parking Logo" class="logo-img">
        </div>

        <div class="forgot-header">
            <h1 class="forgot-title">Crear nueva contraseña</h1>
            @if (ViewBag.RecoveryEmail != null)
            {
                <p class="forgot-subtitle">Cuenta: <strong>@ViewBag.RecoveryEmail</strong></p>
            }
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-credenciales">
                <span class="error-text">⚠️ @ViewBag.Error</span>
            </div>
        }

        <form method="post" asp-controller="Auth" asp-action="ResetPassword" id="resetPasswordForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="input-group">
                <input type="password"
                       id="newPassword"
                       name="newPassword"
                       placeholder="Nueva contraseña"
                       minlength="6"
                       required />
                <div class="error-message" id="errorNewPassword">⚠️ Mínimo 6 caracteres</div>
            </div>

            <div class="input-group">
                <input type="password"
                       id="confirmPassword"
                       name="confirmPassword"
                       placeholder="Confirmar contraseña"
                       minlength="6"
                       required />
                <div class="error-message" id="errorConfirmPassword">⚠️ Las contraseñas no coinciden</div>
            </div>

            <button type="submit" class="login-btn">Guardar nueva contraseña</button>

            <div class="forgot-password">
                <a asp-controller="Auth" asp-action="Login">Volver al inicio de sesión</a>
            </div>
        </form>
    </div>
</div>
