@{
    ViewData["Title"] = "Estado del Servicio";
}

@model ingresos

<div class="page-wrapper">
    <section class="servicio-section">
        <!-- Panel izquierdo: logo -->
        <div class="servicio-header">
            <div class="logo-container">
                <img src="~/img/logo cars parking.png" class="logo-image" alt="Logo Cars Parking"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
                <!-- Fallback si no carga la imagen -->
                <div style="display:none; flex-direction:column; align-items:center; color:#fff;">
                    <div style="font-size:48px;">🚗</div>
                    <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:800; margin-top:8px;">Cars Parking</div>
                    <div style="font-size:11px; letter-spacing:3px; opacity:0.7; margin-top:2px;">SERVICE</div>
                </div>
            </div>
            <div class="header-badge">Parking Service</div>
        </div>

        <!-- Panel derecho: datos -->
        <div class="vehiculo">
            <h1 class="titulo-vehiculo">Mi Vehículo</h1>

            <!-- Tiempo de espera -->
            <div class="header-tiempo-confirmacion" id="tiempoEspera" style="display: none;">
                <div class="etiqueta-llegada-confirmacion">⏱ Tu vehículo llega en: <strong class="timer-display">08:00</strong></div>

                <div class="barra-track-confirmacion">
                    <div class="barra-fill-confirmacion"></div>
                </div>

                <div class="carro-container-confirmacion">
                    <span class="carro-icono">🚗</span>
                    <div class="ruta-puntitos">
                        <span></span><span></span><span></span><span></span><span></span>
                        <span></span><span></span><span></span><span></span><span></span>
                    </div>
                    <span class="destino-icono">📍</span>
                </div>
            </div>

            <p class="titulo-subtexto">Información del servicio activo</p>

            <ol class="descripcion-servicio">
                <li>
                    <p class="campo-label">Placa del Vehículo</p>
                    <h4 class="campo-valor">@Model?.placa</h4>
                </li>
                <li>
                    <p class="campo-label">Número Celular</p>
                    <h4 class="campo-valor">@Model?.telefono</h4>
                </li>
                <li>
                    <p class="campo-label">Estado</p>
                    <h4 class="campo-valor" style="color:#e74c3c; display:flex; align-items:center; gap:6px;">
                        <span style="width:8px;height:8px;background:#e74c3c;border-radius:50%;display:inline-block;box-shadow:0 0 0 3px rgba(231,76,60,0.2)"></span>
                        @Model?.estado_servicio
                    </h4>
                </li>
            </ol>

            <input type="hidden" id="idIngreso" value="@Model?.id_ingreso" />
            <input type="hidden" id="fechaFinServicio" value="@Model?.fecha_fin_servicio?.ToString("o")" />

            @if (Model?.estado_servicio == "solicitado")
            {
                <button class="btn-pagar" id="btn-pagar">
                    <span>🔒</span> Pagar
                </button>
            }
            else
            {
                <button type="button" class="servicio-btn" id="btn-solicitar">
                    🚗 Solicitar Vehículo
                </button>
            }
        </div>
    </section>
</div>
<!-- ======= Modal Comfirmar Solicitud ======= -->
<div class="modal-confirmacion" id="modal-confirmacion" style="display: none;">
    <div class="informacion-solicitud" id="confirmacion">
        <div class="confirmacion">
            <div class="confirmacion-header">
                <div class="check-circle">✓</div>
                <h2 class="confirmacion-titulo">¡Solicitud Enviada!</h2>
                <p class="confirmacion-sub">
                    Hemos notificado a nuestro equipo que has solicitado tu vehículo.
                    En breve, será llevado hasta tu ubicación.

                    Te avisaremos en cuanto esté listo para ti.
                </p>

                <p class="confirmacion-sub">
                    Recuerda que el vehiculo llegara en 20 min
                </p>
            </div>
            <button class="btn-confirmacion btn-pagar" id="btn-confirmacion">
                Aceptar
            </button>
        </div>
    </div>
</div>

<!-- ======= Modal Pedir viculo y Pagar ======= -->

<div class="modal-pagar oculto" id="modal-pagar">

    <!-- Pantalla 1: Resumen y pago -->
    <div class="informacion" id="informacion_1" style="position:relative;">
        <button type="button"
                aria-label="Cerrar"
                onclick="cerrarModalPagar()"
                style="position:absolute;top:12px;right:12px;width:34px;height:34px;border:none;border-radius:50%;background:rgba(0,0,0,0.6);color:#fff;font-size:22px;line-height:1;z-index:20;cursor:pointer;">
            &times;
        </button>

        <div class="header-tiempo">
            <div class="conductor-section">
                <div class="conductor-avatar">👨‍✈</div>
                <div class="conductor-info">
                    <div class="conductor-nombre">@ViewBag.nombreUsuario</div>
                    <div class="conductor-detalle">
                        <span class="placa-tag">@Model?.placa</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="resumen-titulo" style="padding: 16px 28px 0;">Resumen del viaje</div>
        <div style="padding: 0 28px;">
            <div class="resumen-fila">
                <span>Tarifa base</span>
                <span class="resumen-valor" id="tarifa-base">$30.000</span>
            </div>
            <div class="resumen-fila propina-fila">
                <div class="propina-label-container">
                    <span>Propina</span>
                </div>
                <span class="resumen-valor">
                    <select class="input-group" id="select-propina">
                        <option value="0">$0.00</option>
                        <option value="1000">$1.000</option>
                        <option value="2000">$2.000</option>
                        <option value="5000">$5.000</option>
                        <option value="10000">$10.000</option>
                        <option value="20000">$20.000</option>
                        <option value="30000">$30.000</option>
                    </select>
                </span>
            </div>
            <div class="resumen-total-fila">
                <span class="total-label">Total a pagar</span>
                <span class="total-valor" id="total-value">$30.000</span>
            </div>
        </div>

        <div class="pago-section">
            <div class="pago-titulo">Método de pago</div>
            <div class="metodos-grid">
                <button class="metodo-btn activo" onclick="seleccionar(this)">
                    <span class="ico">💵</span>Efectivo
                </button>
                <button class="metodo-btn" onclick="seleccionar(this)">
                    <span class="ico"><i class="fa-solid fa-qrcode"></i></span>QR
                </button>
                <button class="metodo-btn" onclick="seleccionar(this)">
                    <span class="ico">
                        <img src="~/img/nequi.ico" style="width:22px;height:22px;object-fit:contain;" />
                    </span>Nequi
                </button>
            </div>
            <button class="btn-pagar" id="btn-confirmar-pago">
                <span>🔒</span> Confirmar y Pagar
            </button>
        </div>
    </div>

    <!-- Pantalla 2: Confirmación de pago -->
    <div class="informacion" id="informacion_2" style="display:none;">
        <div class="resumen-section-2">

            <div class="confirmacion-header">
                <div class="check-circle">✓</div>
                <h2 class="confirmacion-titulo">¡Pago Confirmado!</h2>
                <p class="confirmacion-sub">Tu servicio ha sido registrado exitosamente</p>
            </div>

            <div class="instruccion-card">
                <div class="instruccion-icono">🏁</div>
                <p class="instruccion-texto">
                    Acércate y pagua a la persona que te entregua el vehiculo
                </p>
            </div>

            <div class="tiempo-card">
                <div class="tiempo-icono-wrap">
                    <span style="font-size:24px;">✅</span>
                </div>
                <div class="tiempo-info">
                    <p class="tiempo-label">Todo listo</p>
                    <p class="tiempo-valor" style="font-size:14px; font-weight:500; color:#666;">
                        Puedes cerrar esta pestaña cuando recibas tu vehículo
                    </p>
                </div>
            </div>

            <div class="tiempo-card" id="confirmacion-metodo-card">
                <div class="tiempo-icono-wrap">
                    <span style="font-size:24px;" id="confirmacion-metodo-icono">💵</span>
                </div>
                <div class="tiempo-info">
                    <p class="tiempo-label">Método de pago</p>
                    <p class="tiempo-valor" style="font-size:16px;" id="confirmacion-metodo-texto">Efectivo</p>
                </div>
                <span style="font-size:18px;color:#27ae60;">✓</span>
            </div>

            <div style="background:linear-gradient(135deg,#d32f2f 0%,#b71c1c 100%);border-radius:14px;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;color:white;">
                <div>
                    <p style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;opacity:0.75;margin:0 0 4px;">Total pagado</p>
                    <p style="font-size:26px;font-weight:800;margin:0;" id="confirmacion-total">$0</p>
                </div>
                <div style="font-size:36px;opacity:0.3;">🧾</div>
            </div>

            <p style="text-align:center;font-size:13px;color:#aaa;margin:0;line-height:1.6;">
                Gracias por usar <strong style="color:#d32f2f;">Cars Parking</strong>.<br>
                ¡Esperamos verte pronto! 🙌
            </p>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/estado-servicio.js" asp-append-version="true"></script>
}
